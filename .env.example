# ============================================================
# ZOLOS — Frontend Environment Configuration
# ============================================================

# Supabase Configuration (Database & Auth)
# Leave empty or use placeholder to enable Offline Mode (localStorage)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Socket.io Server URL (Realtime Multiplayer — Railway Deployment)
# Leave empty for Offline Mode (single-player, no other players)
# Set to your Railway deployment URL for full multiplayer:
#   VITE_SOCKET_URL=https://zolos-map-server-production.up.railway.app
VITE_SOCKET_URL=

# ============================================================
# ZOLOS MAP SERVER — Backend Environment Configuration
# (Place this in server/.env for local dev, or Railway dashboard for production)
# ============================================================
# PORT=3001
# CORS_ORIGINS=http://localhost:3000,https://zolos.online
# CORS_ALLOW_ALL=false
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
