index 4556509..9372915 100644
--- a/src/network/GameSync.js
+++ b/src/network/GameSync.js
@@ -14,6 +14,24 @@ let currentUserId = null;
 let currentUsername = 'Adventurer';
 let currentLevel = 1;
 
+// ============ Deterministic Guest Name ============
+// Generate a consistent guest name from any ID string (always returns same name for same ID)
+export function getDeterministicGuestName(id) {
+    if (!id) return 'Adventurer';
+    let hash = 0;
+    for (let i = 0; i < id.length; i++) {
+        hash = ((hash << 5) - hash) + id.charCodeAt(i);
+        hash |= 0; // Convert to 32bit integer
+    }
+    const code = Math.abs(hash).toString(36).substring(0, 5).toUpperCase();
+    return 'Guest_' + (code || 'X0000');
+}
+
+// Helper: returns true if a name is a generic placeholder
+export function isPlaceholderName(name) {
+    return !name || name === 'Novice' || name === 'Guest' || name === 'Adventurer';
+}
